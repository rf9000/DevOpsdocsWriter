# Azure DevOps Configuration (required)
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PROJECT=your-project-name

# Per-product AL source repos the agent reads, keyed by article-id prefix
# (see src/config/products.ts). At least one is required; a work item whose
# product has no repo configured is skipped with a comment on the item.
# The legacy single TARGET_REPO_PATH is treated as TARGET_REPO_PATH_CB.
# Single source of truth for these paths - skills/prompts reference the variables, never literal paths.
TARGET_REPO_PATH_CB=C:\GeneralDev\your-continia-banking-repo
# TARGET_REPO_PATH_DC=C:\GeneralDev\your-document-capture-repo
# TARGET_REPO_PATH_EM=C:\GeneralDev\your-expense-management-repo
# TARGET_REPO_PATH_PM=C:\GeneralDev\your-payment-management-repo
# TARGET_REPO_PATH_CM=C:\GeneralDev\your-collection-management-repo
# TARGET_REPO_PATH_DO=C:\GeneralDev\your-document-output-repo
# TARGET_REPO_PATH_CF=C:\GeneralDev\your-continia-finance-repo
# TARGET_REPO_PATH_COPP=C:\GeneralDev\your-opplus-repo
# TARGET_REPO_PATH_CS=C:\GeneralDev\your-continia-sustainability-repo

# Local path to the continia.docs.articles repo (read-only: tone, toc, and article-id lookup) (required).
# The processor scopes the agent's search to the folder of the product resolved from each work item.
# Single source of truth for this path - skills/prompts reference the variable, never the literal path.
DOCS_REPO_PATH=C:\GeneralDev\continia.docs.articles

# Optional: work item field used to resolve the product (default: System.AreaPath).
# Products are matched on area-path segments (see src/config/products.ts).
# PRODUCT_FIELD=System.AreaPath

# Optional: tag that marks a work item for documentation (default: write-docs)
# WRITE_DOCS_TAG=write-docs

# Optional: tag added once an article is attached, so documented items are easy to
# spot in the ADO overview (default: Docs-Article-Written)
# DOCS_WRITTEN_TAG=Docs-Article-Written

# Optional: directory the agent writes the finished article into (default: .output)
# OUTPUT_DIR=.output

# Optional: directory holding docsWriter's docs-writing skills, junction-linked into
# the source repo so the agent can invoke them via the Skill tool (default: .claude/skills)
# SKILLS_SOURCE_DIR=.claude/skills

# Optional: polling interval in minutes (default: 15)
# POLL_INTERVAL_MINUTES=15

# Optional: max articles generated per day (default: 5)
# MAX_DOCS_PER_DAY=5

# Optional: Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: max agent turns before aborting with error_max_turns (default: 60)
# MAX_TURNS=60

# Optional: path to the system prompt file (default: src/prompts/write-docs.md)
# PROMPT_PATH=src/prompts/write-docs.md

# Optional: state file directory (default: .state)
# STATE_DIR=.state

# --- Style-guide sync (scripts/sync-style-guide.sh, host-side daily cron job) ---
# Fine-grained GitHub PAT with Contents: read-only access to the style-guide repo (required by the script)
# STYLE_GUIDE_GITHUB_TOKEN=github_pat_...
# Directory containing docker-compose.yml - or the full path to the compose file itself -
# so the script can rebuild the container (required unless --skip-docker)
# STYLE_GUIDE_COMPOSE_DIR=/home/azureuser/teams/continia-banking/docker-compose.yml
# Upstream coordinates (defaults shown; only set to override)
# STYLE_GUIDE_REPO_OWNER=Continia
# STYLE_GUIDE_REPO_NAME=Continia-agent-friendly-style-guidelines
# STYLE_GUIDE_FILE_PATH=docsguidelines/llmfriendly/style-guide.md
# STYLE_GUIDE_BRANCH=main
