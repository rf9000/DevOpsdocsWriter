# Azure DevOps Configuration (required)
AZURE_DEVOPS_PAT=your-pat-here
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PROJECT=your-project-name

# Local path to the AL source repository the agent searches for code (required)
TARGET_REPO_PATH=C:\GeneralDev\your-al-source-repo

# Local path to the continia.docs.articles repo (read for tone, toc, and CB-### lookup) (required)
DOCS_REPO_PATH=C:\GeneralDev\continia.docs.articles

# Optional: tag that marks a work item for documentation (default: write-docs)
# WRITE_DOCS_TAG=write-docs

# Optional: directory the agent writes the finished article into (default: .output)
# OUTPUT_DIR=.output

# Optional: directory holding docsWriter's docs-writing skills, junction-linked into
# the source repo so the agent can invoke them via the Skill tool (default: .claude/skills)
# SKILLS_SOURCE_DIR=.claude/skills

# Optional: polling interval in minutes (default: 15)
# POLL_INTERVAL_MINUTES=15

# Optional: max articles generated per day (default: 5)
# MAX_DOCS_PER_DAY=5

# Optional: Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: path to the system prompt file (default: src/prompts/write-docs.md)
# PROMPT_PATH=src/prompts/write-docs.md

# Optional: state file directory (default: .state)
# STATE_DIR=.state
